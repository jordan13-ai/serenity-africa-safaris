# Sanity Configuration
# Find these in your Sanity project dashboard (manage.sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Email Configuration (Resend)
# Get your API key from resend.com
RESEND_API_KEY=re_your_api_key

# Contact Form Email
# The email address that will receive inquiry notifications
CONTACT_FORM_RECEIVER=info@serenityafricasafaris.com
