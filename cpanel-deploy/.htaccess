# ══════════════════════════════════════════════════════════════
#  Serenity Africa Safaris — cPanel / Apache / LiteSpeed
#  .htaccess for Next.js Static Export (output: 'export')
# ══════════════════════════════════════════════════════════════

Options -Indexes
Options -MultiViews

# ── SECURITY: Block sensitive files ───────────────────────────
<FilesMatch "\.(env|log|sh|bak|sql|tar|gz|json|lock|ts|tsx|jsx|config\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block .git and hidden directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block dotfiles / dotdirectories
    RewriteRule (^|/)\.(?!well-known) - [F,L]

    # ── FORCE HTTPS ──────────────────────────────────────────
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ── WWW → NON-WWW (or reverse — pick one) ───────────────
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # ── PHP MAIL PROXY ───────────────────────────────────────
    # Route /api/email → PHP handler (replaces Next.js API route)
    RewriteRule ^api/email/?$ api/email/index.php [L,QSA]

    # ── STATIC EXPORT ROUTING ────────────────────────────────
    # Next.js static export creates /about/index.html etc.
    # Apache needs to serve these correctly on direct URL access.

    # If the exact file exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # If the exact directory exists, serve its index.html
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Try slug/index.html (trailingSlash: true output)
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.+?)/?$ $1/index.html [L]

    # Try path.html (no trailing slash pages)
    RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}.html -f
    RewriteRule ^(.+)$ $1.html [L]

    # Fallback → 404.html generated by Next.js
    RewriteRule ^ /404.html [L]
</IfModule>

# ── PERFORMANCE: Cache headers ────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — short cache (pages may be redeployed)
    ExpiresByType text/html                 "access plus 1 hour"

    # Static assets — long cache (hashed filenames)
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType application/x-javascript  "access plus 1 year"

    # Images
    ExpiresByType image/webp                "access plus 7 days"
    ExpiresByType image/avif                "access plus 7 days"
    ExpiresByType image/png                 "access plus 7 days"
    ExpiresByType image/jpg                 "access plus 7 days"
    ExpiresByType image/jpeg                "access plus 7 days"
    ExpiresByType image/gif                 "access plus 7 days"
    ExpiresByType image/svg+xml             "access plus 7 days"
    ExpiresByType image/x-icon              "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
</IfModule>

# ── GZIP COMPRESSION ─────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ── SECURITY HEADERS ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Remove server signature
    Header unset X-Powered-By
    Header always unset X-Powered-By

    # Cache control for hashed Next.js chunks
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Cache images
    <FilesMatch "\.(webp|avif|png|jpg|jpeg|gif|ico)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# ── CUSTOM ERROR PAGES ────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html
